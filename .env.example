# ---------------------------------------------------------------------------
# Database (required)
# Any standard PostgreSQL connection string works: local, Docker, a VPS, or any
# managed provider. No vendor-specific variables are required.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/analytics"

# ---------------------------------------------------------------------------
# Better Auth (required)
# Secret used to sign session cookies. Generate one with:
#   openssl rand -base64 32
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET="replace-with-a-random-32-char-string"

# Public base URL of the app. Set this to your deployment URL in production
# (e.g. https://analytics.example.com). Defaults to http://localhost:3000 in dev.
BETTER_AUTH_URL="http://localhost:3000"
